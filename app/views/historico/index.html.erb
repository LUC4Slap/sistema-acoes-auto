<div class="container mt-4">
  <div class="row mb-4">
    <div class="col">
      <h1 class="display-4">Histórico da Ação <%= params[:sigla] %></h1>
      <p class="text-muted">Visualize o histórico completo de preços e datas de busca</p>
    </div>
    <div class="col-auto">
      <%= link_to "← Voltar para Ações", acaos_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <% if @historico.any? %>
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th scope="col">Sigla</th>
              <th scope="col">Preço</th>
              <th scope="col">Data da Busca</th>
              <th scope="col">Variação</th>
            </tr>
          </thead>
          <tbody>
            <% @historico.each_with_index do |acao, index| %>
              <tr>
                <td><strong><%= acao.sigla %></strong></td>
                <td>R$ <%= number_to_currency(acao.preco, unit: "", separator: ",", delimiter: ".") %></td>
                <td><%= acao.created_at.strftime('%d/%m/%Y %H:%M') %></td>
                <td>
                  <% if index < @historico.size - 1 %>
                    <% variacao = ((acao.preco - @historico[index + 1].preco) / @historico[index + 1].preco * 100).round(2) %>
                    <% if variacao > 0 %>
                      <span class="badge bg-success">+<%= variacao %>%</span>
                    <% elsif variacao < 0 %>
                      <span class="badge bg-danger"><%= variacao %>%</span>
                    <% else %>
                      <span class="badge bg-secondary">0%</span>
                    <% end %>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-4">
      <div class="row">
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title text-muted">Preço Atual</h5>
              <p class="display-6 text-primary">R$ <%= number_to_currency(@historico.first.preco, unit: "", separator: ",", delimiter: ".") %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title text-muted">Maior Preço</h5>
              <p class="display-6 text-success">R$ <%= number_to_currency(@historico.maximum(:preco), unit: "", separator: ",", delimiter: ".") %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title text-muted">Menor Preço</h5>
              <p class="display-6 text-danger">R$ <%= number_to_currency(@historico.minimum(:preco), unit: "", separator: ",", delimiter: ".") %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="alert alert-info" role="alert">
      <h4 class="alert-heading">Nenhum histórico encontrado</h4>
      <p>Não há registros de histórico para a ação <strong><%= params[:sigla] %></strong>.</p>
    </div>
  <% end %>
</div>
