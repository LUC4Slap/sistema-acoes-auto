<div class="container mt-4">
  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="row mb-4 align-items-center">
    <div class="col">
      <h1 class="display-4 mb-2">📈 Ações</h1>
      <p class="text-muted">Acompanhe as cotações mais recentes das suas ações</p>
    </div>
    <div class="col-auto">
      <%= link_to new_acao_path, class: "btn btn-primary btn-lg" do %>
        <i class="bi bi-plus-circle"></i> Nova Ação
      <% end %>
    </div>
  </div>

  <% if @acaos.any? %>
    <div class="row mb-3">
      <div class="col">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-2 bg-light">
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-muted small">
                <i class="bi bi-graph-up"></i> Total de ações: <strong><%= @acaos.size %></strong>
              </span>
              <span class="text-muted small">
                <i class="bi bi-clock"></i> Última atualização: <%= Time.current.strftime('%d/%m/%Y %H:%M') %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="acaos" class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
              <tr>
                <th scope="col" class="ps-4">Sigla</th>
                <th scope="col">Preço</th>
                <th scope="col">Data da Busca</th>
                <th scope="col" class="text-center">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% @acaos.each do |acao| %>
                <%= render acao %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <div class="mb-4">
        <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
      </div>
      <h3 class="text-muted mb-3">Nenhuma ação cadastrada</h3>
      <p class="text-muted mb-4">Comece adicionando sua primeira ação para acompanhar as cotações</p>
      <%= link_to new_acao_path, class: "btn btn-primary btn-lg" do %>
        <i class="bi bi-plus-circle"></i> Adicionar Primeira Ação
      <% end %>
    </div>
  <% end %>
</div>
