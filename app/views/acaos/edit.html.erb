<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white py-3">
          <h3 class="mb-0">
            <i class="bi bi-pencil"></i> Editar Ação
          </h3>
        </div>
        <div class="card-body p-4">
          <%= render "form", acao: @acao %>
        </div>
      </div>
      <div class="mt-3 d-flex gap-2">
        <%= link_to @acao, class: "btn btn-outline-info" do %>
          <i class="bi bi-eye"></i> Ver Ação
        <% end %>
        <%= link_to acaos_path, class: "btn btn-outline-secondary" do %>
          <i class="bi bi-arrow-left"></i> Voltar
        <% end %>
        <%= button_to @acao, method: :delete, class: "btn btn-outline-danger", form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta ação?" } } do %>
          <i class="bi bi-trash"></i> Excluir
        <% end %>
      </div>
    </div>
  </div>
</div>
